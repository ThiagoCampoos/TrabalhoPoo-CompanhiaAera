{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "javac-build",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d",
                "bin",
                "comum/*.java",
                "companhia/*.java",
                "voo/*.java",
                "passageiro/*.java",
                "ticket/*.java",
                "checkin/*.java",
                "main/*.java"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$javac"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}