{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "javac-build",
      "type": "shell",
      "command": "javac",
      "args": [
        "-cp",
        "lib/mysql-connector-j-9.5.0.jar",
        "-d",
        "bin",
        "comum/*.java",
        "companhia/*.java",
        "voo/*.java",
        "passageiro/*.java",
        "ticket/*.java",
        "checkin/*.java",
        "admin/*.java",
        "boarding/*.java",
        "despacho/*.java",
        "entrada/*.java",
        "reserva/*.java",
        "main/*.java",
        "user/*.java"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
